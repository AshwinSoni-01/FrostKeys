<helium314.keyboard.keyboard.KlipyPalettesView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:visibility="gone"
    android:background="@android:color/transparent"
    android:paddingTop="6dp">

    <!-- Search Bar Row -->
    <LinearLayout
        android:id="@+id/searchBarContainer"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        android:paddingTop="0dp"
        android:paddingBottom="4dp">

        <FrameLayout
            android:id="@+id/dummySearchBox"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:paddingHorizontal="12dp"
            android:background="@drawable/klipy_search_bar_ripple_bg"
            android:clickable="true"
            android:focusable="false"
            android:focusableInTouchMode="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/searchIcon"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/sym_keyboard_search_lxx"
                    android:layout_marginEnd="8dp" />

                <EditText
                    android:id="@+id/dummySearchTextView"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="@string/klipy_search_hint"
                    android:imeOptions="actionSearch|flagNoExtractUi"
                    android:inputType="text|textNoSuggestions"
                    android:padding="0dp"
                    android:selectAllOnFocus="false"
                    android:singleLine="true"
                    android:textColor="@color/textColorPrimary"
                    android:textColorHint="@color/foreground_weak"
                    android:gravity="center_vertical"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/clearSearchButton"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="?android:attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_close"
                    android:visibility="gone"
                    android:padding="4dp"
                    android:scaleType="fitCenter" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <!-- Header containing Back button and Tabs -->
    <LinearLayout
        android:id="@+id/klipyHeader"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <ImageButton
            android:id="@+id/klipyBackButton"
            android:layout_width="40dp"
            android:layout_height="match_parent"
            android:padding="11dp"
            android:scaleType="fitCenter"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="@string/abc_action_bar_up_description"
            android:layout_marginEnd="4dp" />

        <LinearLayout
            android:id="@+id/klipyTabs"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tabGifs"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/tab_gifs"
                android:textColor="@color/textColorPrimary"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/klipy_tab_background_ripple"
                android:gravity="center"
                android:padding="0dp"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_tab_gif"
                android:drawablePadding="4dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />

            <TextView
                android:id="@+id/tabStickers"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="@string/tab_stickers"
                android:textColor="@color/textColorPrimary"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/klipy_tab_background_ripple"
                android:gravity="center"
                android:padding="0dp"
                android:clickable="true"
                android:focusable="true"
                android:drawableStart="@drawable/ic_tab_stickers"
                android:drawablePadding="4dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/klipyPoweredByText"
        android:layout_width="match_parent"
        android:layout_height="18dp"
        android:gravity="end|center_vertical"
        android:paddingEnd="14dp"
        android:text="@string/klipy_powered_by"
        android:textColor="@color/foreground_weak"
        android:textSize="11sp"
        android:alpha="0.72" />

    <!-- Main Content Frame -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/klipyViewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <TextView
            android:id="@+id/emptyState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/no_recent_items"
            android:textColor="@color/textColorPrimary"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/loadingIndicator"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/clearHistoryConfirmOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#66000000"
            android:clickable="true"
            android:focusable="true"
            android:padding="20dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="@drawable/klipy_confirm_panel_bg"
                android:clickable="true"
                android:focusable="true"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/clearHistoryConfirmTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/klipy_clear_history_confirm_title_gif"
                    android:textColor="@color/textColorPrimary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/clearHistoryConfirmMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/klipy_clear_history_confirm_message"
                    android:textColor="@color/foreground_weak"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/cancelClearHistoryButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/klipy_confirm_secondary_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/cancel"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/confirmClearHistoryButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="6dp"
                        android:layout_weight="1"
                        android:background="@drawable/klipy_confirm_primary_bg"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="@string/klipy_clear_history_confirm_action"
                        android:textColor="@color/textColorPrimary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/clearKlipyHistoryButton"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:layout_marginHorizontal="14dp"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/klipy_clear_history_button_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="18dp"
        android:text="@string/klipy_clear_gif_history"
        android:textColor="@color/textColorPrimary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <helium314.keyboard.keyboard.MainKeyboardView
        android:id="@+id/bottom_row_keyboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />

</helium314.keyboard.keyboard.KlipyPalettesView>
