<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="top"
    android:background="@android:color/transparent"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:paddingHorizontal="8dp"
    android:paddingTop="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="0dp"
        android:paddingTop="0dp"
        android:layout_marginBottom="4dp">
        <ImageButton
            android:id="@+id/btn_back_ai"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:foreground="?android:attr/selectableItemBackground"
            android:contentDescription="Back"
            android:tint="?android:attr/textColorPrimary" />
        <TextView
            android:id="@+id/tv_ai_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="AI Writing Tools"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:textSize="20sp"
            android:paddingStart="8dp"/>

    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <Button
                android:id="@+id/btn_tool_proofread"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_ai_chip"
                android:foreground="?android:attr/selectableItemBackground"
                android:paddingHorizontal="16dp"
                android:text="Proofread"
                android:textAllCaps="false"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:textColor="?android:attr/textColorPrimary" />

            <Button
                android:id="@+id/btn_tool_fix_grammar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_ai_chip"
                android:foreground="?android:attr/selectableItemBackground"
                android:paddingHorizontal="16dp"
                android:text="Fix Grammar"
                android:textAllCaps="false"
                android:elevation="0dp"
                android:stateListAnimator="@null"
                android:textColor="?android:attr/textColorPrimary" />

            <Button android:id="@+id/btn_tool_rewrite"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Rewrite"
                android:foreground="?android:attr/selectableItemBackground"
                android:textAllCaps="false" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:textColor="?android:attr/textColorPrimary"/>

            <Button android:id="@+id/btn_tone_professional"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Professional"
                android:foreground="?android:attr/selectableItemBackground"
                android:textAllCaps="false" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:textColor="?android:attr/textColorPrimary"/>

            <Button android:id="@+id/btn_tone_friendly"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Friendly"
                android:foreground="?android:attr/selectableItemBackground"
                android:textAllCaps="false" android:layout_marginEnd="8dp" android:paddingHorizontal="16dp"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:textColor="?android:attr/textColorPrimary"/>

            <Button android:id="@+id/btn_tool_old_english"
                android:layout_width="wrap_content" android:layout_height="40dp"
                android:background="@drawable/bg_ai_chip" android:text="Old English"
                android:foreground="?android:attr/selectableItemBackground"
                android:textAllCaps="false" android:paddingHorizontal="16dp"
                android:elevation="0dp" android:stateListAnimator="@null"
                android:textColor="?android:attr/textColorPrimary"/>
        </LinearLayout>
    </HorizontalScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginBottom="0dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/vp_ai_carousel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal" />

        <View
            android:id="@+id/glow_border"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:visibility="gone" />

        <helium314.keyboard.keyboard.internal.SparkleDustView
            android:id="@+id/sparkle_dust"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="2dp"
            android:clickable="false"
            android:focusable="false"
            android:importantForAccessibility="no"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/ll_page_indicators"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="0dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="0dp"
        android:paddingBottom="0dp">

        <Button android:id="@+id/btn_copy_text"
            android:layout_width="wrap_content" android:layout_height="40dp"
            android:background="@drawable/bg_ai_chip"
            android:foreground="?android:attr/selectableItemBackground"
            android:text="Copy" android:textColor="?android:attr/textColorPrimary"
            android:textAllCaps="false"
            android:paddingHorizontal="20dp"
            android:layout_marginEnd="8dp"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton android:id="@+id/btn_delete_ai"
            android:layout_width="48dp" android:layout_height="40dp"
            android:background="@drawable/bg_ai_chip"
            android:foreground="?android:attr/selectableItemBackground"
            android:src="@drawable/sym_keyboard_delete_lxx"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:tint="?android:attr/textColorPrimary"
            android:contentDescription="Delete" />
    </LinearLayout>
</LinearLayout>
